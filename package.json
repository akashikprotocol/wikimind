{
  "name": "wikimind",
  "version": "0.1.0",
  "description": "CLI tool that uses LLMs to compile raw documents into a structured, interlinked wiki with auto-generated concepts, backlinks, and indexes. Obsidian-compatible. Based on Andrej Karpathy Post.",
  "author": "Sahil David",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "cli",
    "obsidian",
    "markdown",
    "ai",
    "anthropic",
    "claude",
    "rag",
    "knowledge-management"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akashikprotocol/wikimind"
  },
  "scripts": {
    "build": "tsc"
  },
  "bin": {
    "wikimind": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
